{
  "name": "tracking",
  "version": "0.1.0",
  "description": "Hand-Tracked 3D Knowledge Graph & Latent Space Explorer",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "native:build": "cd native && node-gyp rebuild",
    "native:clean": "cd native && node-gyp clean",
    "package": "electron-builder",
    "package:appimage": "electron-builder --linux AppImage",
    "package:deb": "electron-builder --linux deb",
    "demo": "tsx demos/index.ts",
    "test:live": "bash scripts/live-test.sh",
    "test:live:quick": "bash scripts/live-test.sh --quick",
    "test:live:ci": "bash scripts/live-test.sh --ci"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.14",
    "@react-three/drei": "^9.102.0",
    "@react-three/fiber": "^8.15.0",
    "d3-force-3d": "^3.0.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "three": "^0.162.0",
    "ws": "^8.16.0",
    "zod": "^3.22.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.2.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/three": "^0.162.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^1.3.0",
    "electron": "^28.2.0",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.0.0",
    "eslint": "^8.56.0",
    "happy-dom": "^13.3.0",
    "node-addon-api": "^8.5.0",
    "node-gyp": "^10.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.3.0"
  },
  "build": {
    "appId": "com.tracking.app",
    "productName": "Tracking",
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Science"
    },
    "files": [
      "dist/**/*",
      "native/build/Release/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "assets/samples",
        "to": "samples"
      }
    ]
  }
}
